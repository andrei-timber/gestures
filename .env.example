# Copy to `.env.local` (gitignored) and fill in. Vite inlines VITE_* into the
# client bundle at build time — so this key ships publicly. That's expected for a
# Tier-1 public-read key (gestures-spec.md §3); protect it by restricting the key
# in Google Cloud Console to your domain's HTTP referrers + the Drive API only.

# Google Drive API key — App > APIs & Services > Credentials. See docs/deploy-notes.md.
VITE_GOOGLE_DRIVE_API_KEY=

# Google OAuth 2.0 Client ID (Web application) for Tier-2 drive.file capture (§3/§7,
# M2). NOT a secret — origin-locked to your JS origins (localhost + your domain),
# no client secret used by the browser token flow. Empty disables the Save-to-Drive
# button. Create it: APIs & Services > Credentials > Create > OAuth client ID.
VITE_GOOGLE_OAUTH_CLIENT_ID=
